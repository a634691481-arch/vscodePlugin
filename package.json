{
  "name": "autovue-companion",
  "displayName": "AutoVue Companion",
  "description": "AutoVue Companion",
  "version": "0.0.3",
  "publisher": "vue-variable-method-generator",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/a634691481-arch/vscodePlugin"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscodeplugin.copyVuePath",
        "title": "📋 复制Vue页面路径"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vscodeplugin.copyVuePath",
          "group": "navigation",
          "when": "resourceExtname == .vue"
        }
      ]
    },
    "keybindings": [],
    "configuration": {
      "type": "object",
      "title": "AutoVue Companion"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "pnpm run lint",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
